# ==========================================
# SGIC - Variables de Entorno (Plantilla)
# ==========================================

# --- Base de Datos ---
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=root
# POSTGRES_DB=sgic_db
# POSTGRES_PORT=5432

# --- URL de conexión ---
# DATABASE_URL="postgresql://postgres:root@localhost:5432/sgic_db"

# --- Claves Criptográficas (ES256) ---
# Ejecutar 'python security/generate_keys.py' para autocompletar esto localmente
# JWT_PRIVATE_KEY="reemplazar_con_clave_privada"
# VITE_PUBLIC_KEY="reemplazar_con_clave_publica"

# --- Reglas de Negocio ---
# CAMPING_TOTAL_CAPACITY=50
# CAMPING_OFFLINE_BUFFER=5